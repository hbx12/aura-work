{
  "manifest_version": 3,
  "name": "Aura OS",
  "version": "0.9.0",
  "description": "Connect Chrome to local Aura OS — page reads require per-task approval.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:47826/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'self';"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aura OS"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
