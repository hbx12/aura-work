{
  "name": "aura-work",
  "version": "0.1.6",
  "type": "module",
  "description": "Aura CLI — standalone OpenCode-style terminal interface for Aura Work",
  "author": "hbx12",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hbx12/aura-work.git",
    "directory": "packages/aura-cli"
  },
  "homepage": "https://github.com/hbx12/aura-work/tree/main/packages/aura-cli#readme",
  "bugs": {
    "url": "https://github.com/hbx12/aura-work/issues"
  },
  "keywords": [
    "aura",
    "cli",
    "ai",
    "terminal",
    "coding-agent",
    "llm",
    "openai",
    "anthropic",
    "copilot"
  ],
  "bin": {
    "aura": "./bin/aura-work.js",
    "aura-work": "./bin/aura-work.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/tui.tsx --format esm --dts --external react --external ink",
    "dev": "tsx src/index.ts",
    "dev:tui": "tsx src/tui.tsx",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.0",
    "diff": "^7.0.0",
    "ink": "^6.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-fetch": "^3.3.0",
    "open": "^10.1.0",
    "ora": "^8.0.0",
    "react": "^19.1.0",
    "semver": "^7.6.0",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@aura-os/shared": "*",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/yargs": "^17.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.8.3",
    "vitest": "^4.1.8"
  }
}
