{
  "name": "@aura-os/aura-cli",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "description": "Aura CLI — standalone OpenCode-style terminal interface for Aura Work",
  "bin": {
    "aura-work": "./bin/aura-work.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/tui.tsx --format esm --dts --external react --external ink",
    "dev": "tsx src/index.ts",
    "dev:tui": "tsx src/tui.tsx",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aura-os/shared": "*",
    "yargs": "^17.7.0",
    "chalk": "^5.3.0",
    "node-fetch": "^3.3.0",
    "open": "^10.1.0",
    "semver": "^7.6.0",
    "ora": "^8.0.0",
    "cli-highlight": "^2.1.0",
    "diff": "^7.0.0",
    "ink": "^6.1.0",
    "ink-text-input": "^6.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/yargs": "^17.0.0",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "typescript": "~5.8.3",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "vitest": "^4.1.8"
  }
}
