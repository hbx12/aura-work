{
  "schemaVersion": "1.0",
  "version": "0.1.0-alpha.1",
  "productName": "Aura Work",
  "nodeRuntime": {
    "bundled": true,
    "minVersion": "20.0.0",
    "resourcePath": "node",
    "executable": "node/node.exe",
    "note": "Installed builds use this bundled Node runtime; development builds may use workspace Node."
  },
  "vmImage": {
    "imageId": "aura-linux-workspace",
    "version": "0.1.0-alpha.1",
    "manifestPath": "vm-image/manifest.json",
    "signatureRequired": true
  },
  "sidecars": [
    {
      "id": "aura-agent",
      "port": 47821,
      "resourcePath": "sidecars/aura-agent",
      "entry": "sidecars/aura-agent/dist/index.js"
    },
    {
      "id": "aura-vm-helper",
      "port": 47822,
      "resourcePath": "sidecars/aura-vm-helper",
      "entry": "sidecars/aura-vm-helper/dist/index.js"
    },
    {
      "id": "aura-browser-helper",
      "port": 47823,
      "resourcePath": "sidecars/aura-browser-helper",
      "entry": "sidecars/aura-browser-helper/dist/index.js"
    },
    {
      "id": "aura-plugins-helper",
      "port": 47824,
      "resourcePath": "sidecars/aura-plugins-helper",
      "entry": "sidecars/aura-plugins-helper/dist/index.js"
    },
    {
      "id": "aura-cloud-sync",
      "port": 47825,
      "resourcePath": "sidecars/aura-cloud-sync",
      "entry": "sidecars/aura-cloud-sync/dist/index.js"
    },
    {
      "id": "aura-bridge",
      "port": 47826,
      "resourcePath": "sidecars/aura-bridge",
      "entry": "sidecars/aura-bridge/dist/index.js"
    },
    {
      "id": "aura-computer-use",
      "port": 47828,
      "resourcePath": "sidecars/aura-computer-use",
      "entry": "sidecars/aura-computer-use/dist/index.js"
    }
  ],
  "updates": {
    "source": "github-releases",
    "verification": "minisign",
    "endpointTemplate": "https://github.com/hbx12/aura-work/releases/latest/download/latest.json"
  }
}
