{
  "name": "aura-os",
  "private": true,
  "version": "0.1.0-alpha.1",
  "description": "Aura Work — open-source multi-provider desktop AI agent platform (alpha)",
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "cli/aura-cli",
    "sidecar/aura-agent",
    "sidecar/aura-vm-helper",
    "sidecar/aura-browser-helper",
    "sidecar/aura-plugins-helper",
    "sidecar/aura-cloud-sync",
    "sidecar/aura-bridge",
    "sidecar/aura-computer-use",
    "server/aura-cloud",
    "qa/acceptance-suite"
  ],
  "scripts": {
    "dev": "npm run tauri dev -w @aura-os/desktop",
    "start": "powershell -ExecutionPolicy Bypass -File scripts/start-aura.ps1",
    "dev:web": "npm run dev -w @aura-os/desktop",
    "build": "npm run build -w @aura-os/desktop",
    "build:sidecar": "npm run build -w @aura-os/shared && npm run build -w @aura-os/agent",
    "build:vm": "npm run build -w @aura-os/vm-helper",
    "build:browser": "npm run build -w @aura-os/browser-helper",
    "build:plugins": "npm run build -w @aura-os/plugins-helper",
    "build:cloud-sync": "npm run build -w @aura-os/cloud-sync",
    "build:bridge": "npm run build -w @aura-os/bridge",
    "build:computer-use": "npm run build -w @aura-os/computer-use",
    "build:cli": "npm run build -w @aura-os/cli",
    "build:cloud": "npm run build -w @aura-os/cloud",
    "build:sidecars": "npm run build:sidecar && npm run build:vm && npm run build:browser && npm run build:plugins && npm run build:cloud-sync && npm run build:bridge && npm run build:computer-use",
    "stage:bundle": "node scripts/stage-bundle.mjs",
    "build:all": "npm run build:sidecars && npm run stage:bundle && npm run build:cli",
    "tauri": "npm run tauri -w @aura-os/desktop",
    "sidecar": "npm run start -w @aura-os/agent",
    "vm-helper": "npm run start -w @aura-os/vm-helper",
    "browser-helper": "npm run start -w @aura-os/browser-helper",
    "plugins-helper": "npm run start -w @aura-os/plugins-helper",
    "cloud-sync": "npm run start -w @aura-os/cloud-sync",
    "bridge": "npm run start -w @aura-os/bridge",
    "computer-use": "npm run start -w @aura-os/computer-use",
    "cli": "npm run start -w @aura-os/cli",
    "cloud-server": "npm run start -w @aura-os/cloud",
    "test:rust": "npm run test:rust -w @aura-os/desktop",
    "test:sidecars": "vitest run --config vitest.sidecars.config.ts",
    "test:acceptance": "npm run test -w @aura-os/acceptance-suite",
    "qa": "npm run build:sidecars && npm run build:cloud && npm run build:bridge && npm run test:sidecars && npm run test:rust && npm run test:acceptance",
    "audit:licenses": "node scripts/audit-licenses.mjs",
    "sbom": "npx @cyclonedx/cyclonedx-npm --output-file sbom.json --omit dev"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
