# =============================================================================
# AURA Work — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
# All variables are optional for local development.
# =============================================================================

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Sidecar authentication token (32+ characters, auto-generated if not set)
# Required for production builds, optional for development
# AURA_SIDECAR_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Development Overrides (DANGEROUS — development only)
# -----------------------------------------------------------------------------

# Allow host shell execution (bypasses VM sandbox)
# ⚠️ NEVER enable in production
# AURA_ALLOW_UNSAFE_HOST_EXECUTION=1

# Enable experimental computer-use sidecar
# ⚠️ Experimental — may have security implications
# AURA_ENABLE_EXPERIMENTAL_COMPUTER_USE=1

# -----------------------------------------------------------------------------
# Sidecar Ports (defaults shown)
# -----------------------------------------------------------------------------

# Aura Agent (task engine) port
# AURA_AGENT_PORT=47821

# Aura VM Helper port
# AURA_VM_HELPER_PORT=47822

# Aura Browser Helper port
# AURA_BROWSER_HELPER_PORT=47823

# Aura Plugins Helper port
# AURA_PLUGINS_PORT=47824

# Aura Cloud Sync port
# AURA_CLOUD_SYNC_PORT=47825

# Aura Bridge (Chrome extension + Office add-in) port
# AURA_BRIDGE_PORT=47826

# Aura Computer Use port
# AURA_COMPUTER_USE_PORT=47827

# -----------------------------------------------------------------------------
# Cloud Sync
# -----------------------------------------------------------------------------

# Aura Cloud server URL (for E2EE sync)
# AURA_CLOUD_URL=http://127.0.0.1:47828

# Cloud sync authentication token
# AURA_CLOUD_TOKEN=

# -----------------------------------------------------------------------------
# Build & Release
# -----------------------------------------------------------------------------

# Mark as production release build
# AURA_RELEASE_BUILD=1

# Release version (used by bundle staging)
# AURA_RELEASE_VERSION=0.1.0

# -----------------------------------------------------------------------------
# API Keys (stored in encrypted vault, not here)
# -----------------------------------------------------------------------------
# API keys are managed through the app's Settings → Vault screen.
# They are encrypted with OS-backed secure storage (DPAPI/Keychain/Secret Service).
# DO NOT put API keys in this file.
