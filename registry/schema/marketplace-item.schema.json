{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MarketplaceItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "name",
    "version",
    "summary",
    "description",
    "publisher",
    "icon",
    "cover",
    "categories",
    "tags",
    "risk",
    "auth",
    "install",
    "setup"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$"
    },
    "type": {
      "type": "string",
      "enum": ["skill", "mcp", "plugin"]
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 8
    },
    "description": {
      "type": "string",
      "minLength": 16
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "github": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    },
    "icon": {
      "type": "string",
      "minLength": 1
    },
    "cover": {
      "type": "string",
      "minLength": 1
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "api-key", "pat", "oauth", "oauth-or-pat", "env", "connection-string", "local-file", "local-only"]
        },
        "requiresLogin": { "type": "boolean" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "label"],
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
              "label": { "type": "string", "minLength": 2 },
              "secret": { "type": "boolean" },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["skill", "mcp", "plugin"] },
        "transport": { "type": "string" },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "script": { "type": "string" },
        "prompt": { "type": "string" }
      }
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "setup": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "homepage": { "type": "string" },
    "license": { "type": "string" },
    "repository": { "type": "string" }
  }
}
